  "info": {
    "title": "MCP Bridge API",
    "description": "Relay backend exposing desktop-agent MCP servers over HTTP",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "MeDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "subscription": {
            "type": "string"
          },
          "isActivated": {
            "type": "boolean"
          }
        },
        "required": [
          "username",
          "role",
          "subscription",
          "isActivated"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "user": {
            "type": "string",
            "example": "admin"
          },
          "password": {
            "type": "string",
            "example": "hunter2"
          }
        },
        "required": [
          "user",
          "password"
        ]
      },
      "TokenPairDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "Short-lived JWT used to authenticate API requests"
          },
          "refreshToken": {
            "type": "string",
            "description": "Long-lived opaque token used to obtain a new access token via /auth/refresh"
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "admin",
            "description": "Unique username (lowercase alphanumeric / underscore, no hyphens)"
          },
          "password": {
            "type": "string",
            "example": "hunter2",
            "description": "Password (min 8 chars)"
          },
          "registerSecret": {
            "type": "string",
            "example": "SUPER_SECRET_REGISTER_KEY",
            "description": "Server-side registration secret from env REGISTER_SECRET"
          }
        },
        "required": [
          "username",
          "password",
          "registerSecret"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "admin"
          },
          "refreshToken": {
            "type": "string",
            "description": "The refresh token issued at login/activation"
          }
        },
        "required": [
          "username",
          "refreshToken"
        ]
      },
      "ApiKeyDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "prefix": {
            "type": "string",
            "description": "First few characters of the key, for identification — the rest is never shown again"
          },
          "createdAt": {
            "type": "string"
          },
          "lastUsedAt": {
            "type": "string",
            "nullable": true
          },
          "revokedAt": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "prefix",
          "createdAt",
          "lastUsedAt",
          "revokedAt"
        ]
      },
      "CreateApiKeyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "CI server",
            "description": "A label to tell this key apart from others in the list"
          }
        },
        "required": [
          "name"
        ]
      },
      "CreatedApiKeyDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "prefix": {
            "type": "string",
            "description": "First few characters of the key, for identification — the rest is never shown again"
          },
          "createdAt": {
            "type": "string"
          },
          "lastUsedAt": {
            "type": "string",
            "nullable": true
          },
          "revokedAt": {
            "type": "string",
            "nullable": true
          },
          "key": {
            "type": "string",
            "description": "The full raw API key — shown once, at creation time, and never retrievable again"
          }
        },
        "required": [
          "id",
          "name",
          "prefix",
          "createdAt",
          "lastUsedAt",
          "revokedAt",
          "key"
        ]
      },
      "CustomMcpDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "example": "notes",
            "description": "Unique (per user) name — the public id becomes \"<username>-<name>\""
          },
          "port": {
            "type": "number",
            "example": 3333,
            "description": "Port the local MCP server listens on (on the user's machine)"
          },
          "subPath": {
            "type": "string",
            "example": "/api/mcp",
            "description": "Optional sub-path on the local server, e.g. \"/api/mcp\" reaches http://localhost:<port>/api/mcp"
          },
          "active": {
            "type": "boolean"
          },
          "headers": {
            "type": "object",
            "description": "Custom HTTP headers the agent should attach when calling the local MCP server"
          }
        },
        "required": [
          "id",
          "name",
          "port",
          "active"
        ]
      },
      "AddCustomMcpDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "notes"
          },
          "port": {
            "type": "number",
            "example": 3333
          },
          "subPath": {
            "type": "string",
            "example": "/api/mcp",
            "description": "Optional sub-path on the local server"
          },
          "headers": {
            "type": "object"
          }
        },
        "required": [
          "name",
          "port"
        ]
      },
      "UpdateCustomMcpDto": {
        "type": "object",
        "properties": {
          "port": {
            "type": "number",
            "example": 3333
          },
          "subPath": {
            "type": "string",
            "example": "/api/mcp",
            "description": "Optional sub-path on the local server — send \"\" to clear it"
          },
          "active": {
            "type": "boolean"
          },
          "headers": {
            "type": "object"
          }
        }
      },
      "McpLogWithContextDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "requestId": {
            "type": "string",
            "description": "Correlation id for this proxied request, distinct per attempt"
          },
          "method": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "status": {
            "type": "number",
            "description": "HTTP status returned by the agent — absent if the request failed before a response arrived"
          },
          "ok": {
            "type": "boolean",
            "description": "Whether the request completed with a response, regardless of status code"
          },
          "errorMessage": {
            "type": "string",
            "description": "Set when the request failed (agent offline, timeout, ...)"
          },
          "durationMs": {
            "type": "number"
          },
          "requestBody": {
            "type": "object",
            "description": "Body sent to the local MCP server, if any"
          },
          "responseBody": {
            "type": "object",
            "description": "Body returned by the local MCP server — absent if the request failed before a response arrived"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 timestamp"
          },
          "mcpId": {
            "type": "string"
          },
          "mcpName": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "requestId",
          "method",
          "path",
          "ok",
          "durationMs",
          "timestamp",
          "mcpId",
          "mcpName"
        ]
      },
      "McpLogPageDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/McpLogWithContextDto"
            }
          },
          "total": {
            "type": "number",
            "description": "Total number of matching log entries across all pages"
          },
          "page": {
            "type": "number"
          },
          "pageSize": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "total",
          "page",
          "pageSize"
        ]
      },
      "DeleteMcpLogsDto": {
        "type": "object",
        "properties": {
          "ids": {
            "description": "Delete exactly these log entries (bulk-select in the UI)",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mcpId": {
            "type": "string",
            "description": "Delete every log entry for this one MCP"
          }
        }
      },
      "MarketPlaceItemPreviewImageDto": {
        "type": "object",
        "properties": {
          "fileId": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "fileSize": {
            "type": "number"
          }
        },
        "required": [
          "fileId",
          "filename",
          "mimeType",
          "fileSize"
        ]
      },
      "MarketPlaceItemAssetDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "fileSize": {
            "type": "number"
          },
          "originalFilename": {
            "type": "string"
          },
          "checksum": {
            "type": "string"
          },
          "uploadedBy": {
            "type": "string"
          },
          "downloadCount": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "version",
          "fileSize",
          "originalFilename",
          "checksum",
          "uploadedBy",
          "downloadCount",
          "createdAt"
        ]
      },
      "MarketPlaceItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "ownerUsername": {
            "type": "string"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "unlisted",
              "private"
            ]
          },
          "previewImages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketPlaceItemPreviewImageDto"
            }
          },
          "latestVersion": {
            "type": "string",
            "nullable": true
          },
          "totalDownloadCount": {
            "type": "number"
          },
          "versions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketPlaceItemAssetDto"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "ownerUsername",
          "visibility",
          "previewImages",
          "totalDownloadCount",
          "versions",
          "createdAt",
          "updatedAt"
        ]
      },
      "PaginatedMarketPlaceItemsDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketPlaceItemDto"
            }
          },
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "pageSize": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "total",
          "page",
          "pageSize"
        ]
      },
      "MyMarketPlaceDownloadDto": {
        "type": "object",
        "properties": {
          "marketPlaceItemId": {
            "type": "string"
          },
          "itemName": {
            "type": "string"
          },
          "downloadedVersion": {
            "type": "string",
            "description": "The version this user last downloaded"
          },
          "latestVersion": {
            "type": "string",
            "description": "The item's current latest version, if it still exists",
            "nullable": true
          },
          "updateAvailable": {
            "type": "boolean",
            "description": "True if the item has a newer version than the one downloaded"
          },
          "downloadedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "marketPlaceItemId",
          "itemName",
          "downloadedVersion",
          "updateAvailable",
          "downloadedAt"
        ]
      },
      "CreateMarketPlaceItemDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "my-cool-mcp"
          },
          "description": {
            "type": "string",
            "example": "Does cool things."
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "unlisted",
              "private"
            ],
            "default": "private"
          }
        },
        "required": [
          "name"
        ]
      },
      "UpdateMarketPlaceItemDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "my-cool-mcp"
          },
          "description": {
            "type": "string",
            "example": "Does cool things."
          }
        }
      },
      "ChangeVisibilityDto": {
        "type": "object",
        "properties": {
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "unlisted",
              "private"
            ]
          }
        },
        "required": [
          "visibility"
        ]
      },
      "AddVersionDto": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "example": "1.0.0"
          }
        },
        "required": [
          "version"
        ]
      },
      "DownloadLinkDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expiresAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "token",
          "expiresAt"
        ]
      }
    }
  }
}