          },
          "401": {
            "description": "Missing or invalid JWT"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get the currently authenticated user",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns an access token and a refresh token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPairDto"
                }
              }
            }
          },
          "401": {
            "description": "Wrong username or password"
          }
        },
        "summary": "Log in and receive an access + refresh token pair",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/register": {
      "post": {
        "description": "Requires a valid `REGISTER_SECRET` env value in the request body to prevent open registration. Returns the generated activation hash (to be sent via email in a real deployment).",
        "operationId": "register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created — returns the activation hash in dev mode"
          },
          "401": {
            "description": "Invalid register secret"
          },
          "409": {
            "description": "Username or email already taken"
          }
        },
        "summary": "Register a new user",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/activate": {
      "get": {
        "description": "Verifies the activation hash and marks the account as active. Returns an access + refresh token pair so the user is immediately logged in after activation.",
        "operationId": "activateAccount",
        "parameters": [
          {
            "name": "hash",
            "required": true,
            "in": "query",
            "description": "The MD5 activation hash from the registration response",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account activated — returns an access + refresh token pair",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPairDto"
                }
              }
            }
          },
          "404": {
            "description": "Invalid or already-used activation hash"
          }
        },
        "summary": "Activate a user account",
        "tags": [
          "auth"
        ]
      }
    },
    "/auth/refresh": {
      "post": {
        "description": "Refresh tokens are single-use — every call rotates in a new one, invalidating the old one.",
        "operationId": "refresh",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns a new access + refresh token pair",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPairDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid, expired, or already-used refresh token"
          }
        },
        "summary": "Exchange a refresh token for a new access + refresh token pair",
        "tags": [
          "auth"
        ]
      }
    },
