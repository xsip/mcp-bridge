{
  "compileOnSave": false,
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@mcp-bridge/contracts": ["./libs/api/contracts/src/index.ts"],
      "@mcp-bridge/core": ["./libs/api/core/src/index.ts"],
      "@mcp-bridge/websocket": ["./libs/api/websocket/src/index.ts"],
      "@mcp-bridge/common": ["./libs/api/common/src/index.ts"],
      "@mcp-bridge/config": ["./libs/api/config/src/index.ts"],
      "@mcp-bridge/logging": ["./libs/api/logging/src/index.ts"],
      "@mcp-bridge/utils": ["./libs/api/utils/src/index.ts"],
      "@mcp-bridge/ui-client": ["./libs/ui/client/src/index.ts"],
      "@mcp-bridge/ui-components": ["./libs/ui/components/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
