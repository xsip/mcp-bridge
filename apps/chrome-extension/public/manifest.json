{
  "manifest_version": 3,
  "name": "MCP Bridge Agent",
  "version": "1.0.0",
  "description": "Tunnels your local MCP servers to your MCP Bridge account, right from the browser — no desktop app required.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
